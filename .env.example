ANTHROPIC_API_KEY=         # Required — Claude API for script generation
GEMINI_API_KEY=            # Required — Gemini TTS audio generation
TAVILY_API_KEY=            # Optional — web search enrichment (skipped without it)
GITHUB_TOKEN=              # Required — creating releases and committing feed
GITHUB_REPO=owner/repo     # Required — repository for releases + pages
PODCAST_BASE_URL=          # Required — e.g. https://owner.github.io/the-rest-of-us
PODCAST_TITLE=The Rest of Us
PODCAST_DESCRIPTION=AI tech news for the technically literate. Two hosts, sceptical optimism, no cheerleading.
PODCAST_AUTHOR=The Rest of Us
HF_TOKEN=

# Gemini voice selection (defaults shown)
# GEMINI_VOICE_KIT=Zephyr
# GEMINI_VOICE_DEAN=Gacrux

# Schedule / greeting (optional)
# PUBLISH_HOUR=7                  # Hour for RSS pubDate + greeting (default: 7)
# PUBLISH_TIMEZONE=Europe/London  # IANA timezone (default: Europe/London)

# Rhythm analysis tool (optional — only needed for `uv run python scripts/rhythm_analyze.py`)
# HF_TOKEN=                       # HuggingFace token for pyannote diarization
#                                 # Accept all three user agreements (3.1 internally depends on community-1):
#                                 #   https://huggingface.co/pyannote/speaker-diarization-3.1
#                                 #   https://huggingface.co/pyannote/segmentation-3.0
#                                 #   https://huggingface.co/pyannote/speaker-diarization-community-1
