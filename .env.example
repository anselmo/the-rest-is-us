ANTHROPIC_API_KEY=         # Required — Claude API for script generation
ELEVENLABS_API_KEY=        # Required — TTS audio generation
ELEVENLABS_VOICE_ID_ALEX=  # Required — pre-created voice for Alex
ELEVENLABS_VOICE_ID_SAM=   # Required — pre-created voice for Sam
TAVILY_API_KEY=            # Optional — web search enrichment (skipped without it)
GITHUB_TOKEN=              # Required — creating releases and committing feed
GITHUB_REPO=owner/repo     # Required — repository for releases + pages
PODCAST_BASE_URL=          # Required — e.g. https://owner.github.io/hn-ai-podcast
PODCAST_TITLE=HN Signal
PODCAST_DESCRIPTION=Daily AI stories from Hacker News, discussed in plain language.
PODCAST_AUTHOR=HN Signal
